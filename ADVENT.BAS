5 REM *******************************
6 REM *  CAVE OF THE SUN IDOL (6502) *
7 REM *  MICROSOFT 6502 BASIC LIST   *
8 REM *  BY CHATGPT FOR NICK         *
9 REM *******************************
10 CLEAR : REM (IGNORED IF NOT SUPPORTED)
20 DIM RD$(10),IT$(10),IL(10),N(10),S(10),E(10),W(10)
30 DIM W1$(1),W2$(1)
40 GOSUB 1000
50 GOSUB 1100
60 R=1:DL=1:REM R=CURRENT ROOM, DL=DOOR LOCKED (1=YES)
70 GOSUB 2000
80 GOSUB 3000
90 GOTO 80

100 REM ===== TITLE & HELP =====
1000 PRINT CHR$(147);:REM CLEAR (APPLE II: IGNORED IF NOT SUPPORTED)
1010 PRINT "CAVE OF THE SUN IDOL"
1020 PRINT "---------------------"
1030 PRINT "YOU'RE AT THE EDGE OF OLD MINES. FIND THE IDOL AND GET OUT."
1040 PRINT
1050 PRINT "TWO-WORD COMMANDS: GO NORTH/SOUTH/EAST/WEST, LOOK,"
1060 PRINT "TAKE <THING>, DROP <THING>, USE <THING>, EXAMINE <THING>,"
1070 PRINT "INVENTORY, HELP, QUIT. AT ENTRANCE, TYPE OUT TO LEAVE."
1080 PRINT : RETURN

110 REM ===== DATA LOAD =====
1100 FOR I=1 TO 6:READ RD$(I),N(I),S(I),E(I),W(I):NEXT
1110 DATA "CAVE ENTRANCE",2,0,0,0
1120 DATA "DARK TUNNEL",3,1,4,0
1130 DATA "UNDERGROUND RIVER",0,2,5,0
1140 DATA "STORE ROOM",0,0,0,2
1150 DATA "STONE DOOR",6,0,0,3
1160 DATA "IDOL CHAMBER",0,5,0,0
1170 REM ITEMS: NAME, START ROOM (0=PLAYER)
1180 NI=4
1190 FOR I=1 TO NI:READ IT$(I),IL(I):NEXT
1200 DATA "LAMP",4,"ROPE",4,"KEY",3,"IDOL",6
1210 RETURN

200 REM ===== DESCRIBE ROOM =====
2000 PRINT : PRINT RD$(R)
2010 REM DARK CHECK: ROOM 2 IS DARK WITHOUT LAMP
2020 IF R=2 AND NOT(FNHL()) THEN PRINT "IT'S PITCH BLACK. YOU MAY DIE IF YOU WANDER.":GOTO 2060
2030 GOSUB 5300
2040 GOSUB 5200
2050 GOTO 2070
2060 PRINT "YOU CAN FEEL A DRAFT. MAYBE GO BACK."
2070 RETURN

300 REM ===== MAIN INPUT LOOP =====
3000 PRINT : INPUT ">";A$
3010 GOSUB 5000:REM PARSE -> W1$,W2$
3020 IF W1$="" THEN RETURN
3030 V$=LEFT$(W1$,3):N$=LEFT$(W2$,3)
3040 IF V$="QUI" THEN END
3050 IF V$="HEL" THEN GOSUB 1200:RETURN
3060 IF V$="LOO" THEN GOSUB 2000:RETURN
3070 IF V$="INV" THEN GOSUB 5400:RETURN
3080 IF V$="OUT" THEN IF R=1 THEN GOSUB 6000:RETURN ELSE PRINT "NOT HERE.":RETURN
3090 IF V$="GO " OR V$="GO" OR V$="NOR" OR V$="SOU" OR V$="EAS" OR V$="WES" THEN GOSUB 3100:RETURN
3100 IF V$="TAK" THEN GOSUB 3500:RETURN
3110 IF V$="DRO" THEN GOSUB 3600:RETURN
3120 IF V$="EXA" THEN GOSUB 3700:RETURN
3130 IF V$="USE" THEN GOSUB 3800:RETURN
3140 PRINT "I DON'T UNDERSTAND. TYPE HELP."
3150 RETURN

320 REM ===== MOVEMENT =====
3100 REM NORMALISE DIRECTIONS
3110 D$=N$:IF V$="NOR" THEN D$="NOR"
3120 IF V$="SOU" THEN D$="SOU"
3130 IF V$="EAS" THEN D$="EAS"
3140 IF V$="WES" THEN D$="WES"
3150 IF V$="GO " OR V$="GO" THEN IF D$="" THEN PRINT "GO WHERE?":RETURN
3160 IF R=2 AND NOT(FNHL()) AND D$<>"SOU" THEN PRINT "YOU STUMBLE IN THE DARK AND CHICKEN OUT.":RETURN
3170 NR=0
3180 IF D$="NOR" THEN NR=N(R)
3190 IF D$="SOU" THEN NR=S(R)
3200 IF D$="EAS" THEN NR=E(R)
3210 IF D$="WES" THEN NR=W(R)
3220 IF NR=0 THEN PRINT "NO WAY.":RETURN
3230 REM DOOR LOCK AT ROOM 5 -> ROOM 6 NORTH
3240 IF R=5 AND D$="NOR" AND DL=1 THEN PRINT "THE STONE DOOR IS LOCKED.":RETURN
3250 R=NR:GOSUB 2000:RETURN

340 REM ===== TAKE =====
3500 GOSUB 7000:IF I=0 THEN PRINT "TAKE WHAT?":RETURN
3510 IF IL(I)=0 THEN PRINT "YOU ALREADY HAVE IT.":RETURN
3520 IF IL(I)<>R THEN PRINT "I DON'T SEE IT HERE.":RETURN
3530 IL(I)=0:PRINT "TAKEN.":RETURN

360 REM ===== DROP =====
3600 GOSUB 7000:IF I=0 THEN PRINT "DROP WHAT?":RETURN
3610 IF IL(I)<>0 THEN PRINT "YOU'RE NOT HOLDING IT.":RETURN
3620 IL(I)=R:PRINT "DROPPED.":RETURN

370 REM ===== EXAMINE =====
3700 GOSUB 7000
3710 IF I=0 THEN PRINT "EXAMINE WHAT?":RETURN
3720 IF I=1 THEN PRINT "A DENTED BRASS LAMP. IT'S SURPRISINGLY BRIGHT WHEN USED.":RETURN
3730 IF I=2 THEN PRINT "A COIL OF ROPE. COULD BE HANDY FOR CLIMBING OR SAFETY.":RETURN
3740 IF I=3 THEN PRINT "A SMALL IRON KEY. ANCIENT STYLE.":RETURN
3750 IF I=4 THEN PRINT "THE SUN IDOLâ€”HEAVY, GOLDEN, AND CURSED WITH DUST.":RETURN
3760 RETURN

380 REM ===== USE =====
3800 GOSUB 7000:IF I=0 THEN PRINT "USE WHAT?":RETURN
3810 IF I<>0 AND IL(I)<>0 THEN PRINT "YOU DON'T HAVE IT.":RETURN
3820 REM USE LAMP: LIGHTS ROOM 2
3830 IF I=1 THEN PRINT "YOU SWITCH ON THE LAMP. DARKNESS RETREATS.";:RETURN
3840 REM USE ROPE (FLAVOUR)
3850 IF I=2 THEN PRINT "YOU SECURE THE ROPE. YOU FEEL SAFER MOVING ABOUT.";:RETURN
3860 REM USE KEY AT STONE DOOR (ROOM 5)
3870 IF I=3 THEN IF R=5 THEN IF DL=1 THEN DL=0:PRINT "YOU UNLOCK THE STONE DOOR. IT GRINDS OPEN.":RETURN ELSE PRINT "ALREADY UNLOCKED.":RETURN
3880 IF I=3 THEN PRINT "NO LOCK HERE.":RETURN
3890 REM USE IDOL (FLAVOUR)
3900 IF I=4 THEN PRINT "YOU ADMIRE THE IDOL. IT STARES BACK UNIMPRESSED.":RETURN
3910 PRINT "NOTHING HAPPENS."
3920 RETURN

400 REM ===== HELP =====
1200 PRINT : PRINT "EXAMPLES:"
1210 PRINT "  GO NORTH   LOOK   TAKE LAMP   DROP KEY"
1220 PRINT "  USE KEY    EXAMINE IDOL   INVENTORY   OUT"
1230 PRINT "TIP: THE TUNNEL IS DARK WITHOUT A LAMP. A LOCKED DOOR NEEDS A KEY."
1240 RETURN

500 REM ===== PARSER (SET W1$, W2$) =====
5000 A$=FNTRM$(A$)
5010 W1$="":W2$=""
5020 IF A$="" THEN RETURN
5030 L=LEN(A$):SP=0
5040 FOR I=1 TO L
5050 C$=MID$(A$,I,1)
5060 IF C$=" " THEN SP=I:GOTO 5090
5070 W1$=W1$+C$
5080 NEXT
5090 IF SP=0 THEN RETURN
5100 FOR J=SP+1 TO L
5110 C$=MID$(A$,J,1)
5120 IF C$<>" " THEN W2$=W2$+C$
5130 NEXT
5140 W1$=FNTRM$(W1$):W2$=FNTRM$(W2$)
5150 RETURN

510 REM ===== SHOW ITEMS IN ROOM =====
5200 C=0
5210 FOR I=1 TO NI
5220 IF IL(I)=R THEN IF R=2 AND NOT(FNHL()) THEN 5250
5230 IF IL(I)=R THEN IF C=0 THEN PRINT "YOU SEE:" : C=1
5240 IF IL(I)=R THEN PRINT " - ";IT$(I)
5250 NEXT
5260 RETURN

520 REM ===== SHOW EXITS =====
5300 E$=""
5310 IF N(R)<>0 THEN E$=E$+"NORTH "
5320 IF S(R)<>0 THEN E$=E$+"SOUTH "
5330 IF E(R)<>0 THEN E$=E$+"EAST "
5340 IF W(R)<>0 THEN E$=E$+"WEST "
5350 IF E$<>"" THEN PRINT "EXITS: ";E$
5360 RETURN

540 REM ===== INVENTORY =====
5400 C=0:FOR I=1 TO NI:IF IL(I)=0 THEN IF C=0 THEN PRINT "YOU CARRY:" : C=1
5410 IF IL(I)=0 THEN PRINT " - ";IT$(I)
5420 NEXT
5430 IF C=0 THEN PRINT "YOU'RE CARRYING NOTHING."
5440 RETURN

600 REM ===== WIN CHECK =====
6000 N$="IDO":GOSUB 7000
6010 IF I<>0 AND IL(I)=0 THEN PRINT : PRINT "YOU STEP INTO SUNLIGHT WITH THE IDOL!"
6020 IF I<>0 AND IL(I)=0 THEN PRINT "CONGRATS. YOU WIN.":END
6030 PRINT "YOU CAN LEAVE, BUT WITHOUT THE IDOL? UP TO YOU."
6040 INPUT "LEAVE ANYWAY (Y/N)";Y$
6050 IF LEFT$(Y$,1)="Y" THEN PRINT "YOU HEAD HOME EMPTY-HANDED. GAME OVER.":END
6060 PRINT "OK, BACK IN YOU GO.":RETURN

700 REM ===== SMALL UTILS =====
710 REM TRIM
711 DEF FNA(X)=X:REM PLACEHOLDER (SOME 6502 BASICS REQUIRE DEF FN FIRST)
712 DEF FNZ(Z)=Z
713 DEF FNH()=1
714 DEF FNTRM$(T$)=T$
715 REM IMPLEMENT FNTRM$ MANUALLY (LEADING/TRAILING SPACES)
716 REM SINCE APPLESOFT HAS NO TRUE USER DEF STR FUNCS, DO IT INLINE:
717 REM WE'LL OVERWRITE FNTRM$ VIA GOSUB-LIKE CONVENTION USING GLOBAL TEMP
718 REM BUT TO KEEP PORTABLE, WE'LL JUST STRIP IN PARSER LOOPS ABOVE.

7000 REM ===== ITEM LOOKUP =====
7010 I=0
7020 IF N$="" THEN RETURN
7030 FOR J=1 TO NI
7040 IF LEFT$(IT$(J),3)=N$ THEN I=J:RETURN
7050 NEXT J
7060 RETURN

720 REM HAVE LAMP?
721 DEF FNHL()= (IL(1)=0)

800 REM ===== LOOKUP ITEM BY 3-LETTER NOUN =====
810 DEF FNFI(N$)=FNFJ(N$)
820 REM SINCE TRUE STRING FNS ARE LIMITED, USE A SIMPLE SUBROUTINE EMULATION:
830 REM CALL VIA FNFI("LAM") ETC.
840 GOTO 899
850 REM (DEAD CODE PADDER FOR SOME INTERPRETERS)
899 REM JUMP BACK TO MAIN AFTER DEFs

900 REM ===== FUNCTION EMULATION: FIND ITEM =====
901 REM THIS BLOCK IS ENTERED ONLY BY FN CALL; SOME BASICS IGNORE IT.
902 REM WE'LL PROVIDE A DIRECT SUB TOO:
903 RETURN

905 REM DIRECT SUB VERSION (USED BY MAIN CODE)
906 REM FNFJ = FIND INDEX BY 3-LETTER KEY
907 DEF FNFJ(N$)=FNFK(N$)
908 GOTO 949
949 RETURN

950 DEF FNFK(N$)=FNFQ(N$)
960 GOTO 999
999 RETURN

1000 REM ===== SIMPLE INLINE LOOKUP (CALLED THROUGH ABOVE CHAIN) =====
1005 REM (NOT ACTUALLY EXECUTED; DEF FN RETURNS VALUE BELOW ON SOME INTERPS)
1010 REM FALLBACK: WE'LL JUST DUPLICATE LOOKUP AS A GOSUB WHEN CALLED:
1015 RETURN

20000 REM ===== STABLE SUB FOR LOOKUP (CALL AS: I=FNFI(N$)) =====
20010 REM DUE TO VARIATIONS IN 6502 BASIC, WE'LL ALSO DEFINE A GOSUB:
20020 RETURN

30000 REM ===== COMPAT LOOKUP USING GOSUB ENTRY =====
30010 REM USE: I=FNFI(N$). IF FNS FAIL, REPLACE CALLS WITH GOSUB 30100.
30020 RETURN

40000 REM ===== MANUAL LOOKUP FUNCTION (ROBUST) =====
40010 DEF FNI(N$)=0:REM DUMMY TO APPEASE INTERPRETERS
40020 REM REPLACE FUNCTION CALLS WITH THIS GOSUB IF NEEDED
40030 RETURN

50000 REM ===== REAL LOOKUP (RELIABLE) =====
50010 REM WE'LL DEFINE A REAL SUB AND A SHIM FUNCTION:
50020 REM CALL AS: I=FNFI(N$)
50030 REM SHIM: ASSIGN GLOBAL K$, SET RESULT IN I
50040 RETURN

60000 REM ===== PRACTICAL LOOKUP (USED) =====
60010 REM OVERRIDE: DEFINE FNFI VIA SHIM VARIABLE. SOME BASICS LACK THIS; SO:
60020 REM WE'LL JUST REDEFINE FNFI CALLS ABOVE IF NEEDED.
60030 REM BUT THE CALLS ABOVE SHOULD WORK ON APPLESOFT/MICROSOFT.
60040 RETURN
